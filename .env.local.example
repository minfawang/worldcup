# Anthropic API key used for match predictions.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the exact Claude model IDs used by the app.
# Defaults are set in lib/models.ts and can be updated as new models ship.
# CLAUDE_SONNET_MODEL=claude-sonnet-5
# CLAUDE_OPUS_MODEL=claude-opus-4-8

# Optional: durable, Vercel-compatible storage for predictions (Upstash Redis).
# When both are set, predictions persist across restarts and are shared across
# serverless instances. When unset, predictions fall back to a local JSON file
# (.data/predictions.json), which is fine for local dev but not for Vercel.
# Get these from an Upstash Redis database (https://upstash.com) or the Vercel
# Marketplace Upstash integration.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
